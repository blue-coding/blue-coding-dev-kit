  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#3E5C76", "fontStyle": "italic" }
    },
    {
      "name": "Doc comments",
      "scope": ["comment.block.documentation", "comment.line.documentation"],
      "settings": { "foreground": "#4A6C84", "fontStyle": "italic" }
    },
    {
      "name": "JSDoc tags",
      "scope": ["storage.type.class.jsdoc", "punctuation.definition.block.tag.jsdoc", "entity.name.type.instance.jsdoc"],
      "settings": { "foreground": "#5ABFED" }
    },

    {
      "name": "Keywords — control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.return",
        "keyword.control.throw",
        "keyword.control.try",
        "keyword.control.catch",
        "keyword.control.finally",
        "keyword.control.trycatch",
        "keyword.control.new",
        "keyword.control.delete",
        "keyword.control.typeof",
        "keyword.control.void",
        "keyword.control.in",
        "keyword.control.of",
        "keyword.other.important",
        "keyword.other"
      ],
      "settings": { "foreground": "#0091CE", "fontStyle": "bold" }
    },
    {
      "name": "Keywords — storage",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.declaration",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.instanceof",
        "keyword.operator.expression.in",
        "keyword.operator.expression.of",
        "keyword.operator.expression.void",
        "keyword.operator.expression.delete",
        "keyword.operator.new",
        "keyword.operator.delete"
      ],
      "settings": { "foreground": "#1F96DB" }
    },
    {
      "name": "Keywords — access modifiers",
      "scope": [
        "storage.modifier.access",
        "keyword.modifier",
        "storage.modifier.abstract",
        "storage.modifier.async",
        "storage.modifier.const",
        "storage.modifier.export",
        "storage.modifier.extends",
        "storage.modifier.final",
        "storage.modifier.implements",
        "storage.modifier.import",
        "storage.modifier.override",
        "storage.modifier.private",
        "storage.modifier.protected",
        "storage.modifier.public",
        "storage.modifier.readonly",
        "storage.modifier.sealed",
        "storage.modifier.static"
      ],
      "settings": { "foreground": "#0091CE" }
    },

    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.ternary",
        "keyword.operator.optional",
        "keyword.operator.nullish"
      ],
      "settings": { "foreground": "#6BA4BF" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#4A6C84" }
    },

    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template",
        "string.other"
